{
  "name": "@itzrnvr/omp-supervisor",
  "version": "0.5.0-omp1",
  "description": "An oh-my-pi (OMP) extension that supervises the coding agent and steers it toward a defined outcome",
  "author": "tintinweb",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun run test-harness.ts && bun run test-interactive.ts",
    "test:noninteractive": "bun run test-harness.ts",
    "test:interactive": "bun run test-interactive.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/itzrnvr/omp-supervisor.git"
  },
  "homepage": "https://github.com/itzrnvr/omp-supervisor#readme",
  "bugs": {
    "url": "https://github.com/itzrnvr/omp-supervisor/issues"
  },
  "keywords": [
    "omp-package",
    "omp-extension",
    "oh-my-pi",
    "supervisor",
    "steering",
    "outcome",
    "agent",
    "productivity"
  ],
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": "*",
    "@oh-my-pi/pi-ai": "*",
    "@oh-my-pi/pi-tui": "*",
    "@oh-my-pi/pi-agent-core": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "omp-test-harness": "file:../omp-test-harness"
  },
  "omp": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
